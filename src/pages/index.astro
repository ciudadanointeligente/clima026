---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const medidas = await getCollection('medidas');
---

<Layout title="Evaluación de Medidas Legislativas" description="Sitio web para mostrar la evaluación realizada a propuestas y medidas legislativas.">
  <div class="px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold mb-4">Evaluación de Medidas Legislativas</h1>
    <p class="mb-6 text-muted">
      Este sitio muestra la evaluación realizada a propuestas y medidas legislativas,
      organizadas por categorías, subcategorías e indicadores de evaluación.
    </p>
    <p class="mb-8">
      <a href="/keystatic" class="text-primary hover:underline cursor-pointer transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">Ir al panel de administración</a>
    </p>

    <h2 class="text-2xl font-semibold mb-4">Medidas Evaluadas</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        medidas.map(medida => (
          <a
            href={`/medidas/${medida.id}`}
            class="block rounded-xl border border-border bg-white p-5 shadow-sm transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            <h3 class="text-lg font-semibold text-text">{medida.data.nombre}</h3>
            {
              medida.data.indicadores && medida.data.indicadores.length > 0 && (
                <p class="mt-2 text-sm text-muted">
                  {medida.data.indicadores.length} indicador{medida.data.indicadores.length !== 1 ? 'es' : ''}
                </p>
              )
            }
          </a>
        ))
      }
    </div>
  </div>
</Layout>
